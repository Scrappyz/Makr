{
  "manifestVersion": 1,

  "metadata": {
    "name": "Python Project",

    "description": [
      "Production-ready Python project template.",
      "Supports optional testing, Docker, GitHub Actions, and documentation."
    ],

    "tags": [
      "python",
      "pytest",
      "docker",
      "github-actions"
    ]
  },

  "initialization": {
    "parameters": [
      {
        "key": "project",
        "name": "Project Name",
        "description": "The name of your project.",
        "defaultValue": "My Cool Project",
        "interpolate": true
      },
      {
        "key": "author",
        "name": "Author Name",
        "description": "The name of the project author.",
        "required": true,
        "interpolate": true
      },
      {
        "key": "withUnitTests",
        "name": "Include Unit Tests",
        "description": "Whether to include unit testing setup with pytest.",
        "defaultValue": true,
        "interpolate": false
      }
    ],

    "selection": {
      "include": [
        "**/*"
      ],

      "exclude": [
        ".makr",
        ".makr/**"
      ]
    },

    "interpolation": {
      "prefix": "!",
      "suffix": "!",

      "targets": {
        "contents": {
          "include": [
            "!project!/**/*.py"
          ],

          "exclude": [

          ]
        },

        "filenames": {
          "include": [
            "!project!",
            "!project!/**",
            "test/**"
          ],

          "exclude": []
        }
      }
    },

    "rules": [
      {
        "if": {
          "parameter": "withUnitTests",
          "equals": false
        },

        "then": {
          "add": {
            "selection": {
              "exclude": [
                "test/**",
                "test"
              ]
            }
          }
        }
      }
    ]

  }
}