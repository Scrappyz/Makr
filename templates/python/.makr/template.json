{
  "manifestVersion": 1,

  "metadata": {
    "name": "Python Project",

    "description": [
      "Production-ready Python project template.",
      "Supports optional testing, Docker, GitHub Actions, and documentation."
    ],

    "tags": [
      "python",
      "pytest",
      "docker",
      "github-actions"
    ]
  },

  "initialization": {
    "parameters": [
      {
        "key": "project",
        "name": "Project Name",
        "description": "The name of your project.",
        "defaultValue": "My Cool Project",
        "interpolate": true
      },
      {
        "key": "author",
        "name": "Author Name",
        "description": "The name of the project author.",
        "required": true,
        "interpolate": true
      },
      {
        "key": "withUnitTests",
        "name": "Include Unit Tests",
        "description": "Whether to include unit testing setup with pytest.",
        "defaultValue": true,
        "interpolate": false
      },
      {
        "key": "someNumber",
        "name": "A number"
      }
    ],

    "selection": {
      "include": [
        "**/*"
      ],

      "exclude": [
        ".makr",
        ".makr/**"
      ]
    },

    "interpolation": {
      "prefix": "!",
      "suffix": "!",

      "targets": {
        "content": {
          "include": [
            "!project!/**/*.py"
          ],

          "exclude": [

          ]
        },

        "path": {
          "include": [
            "!project!",
            "!project!/**"
          ],

          "exclude": []
        }
      }
    },

    "rules": [
      {
        "if": {
          "parameter": "someNumber",
          "notEquals": 5
        },

        "then": {
          "add": {
            "selection": {
              "exclude": [
                "tests/**"
              ]
            }
          }
        }
      },
      {
        "if": {
          "all": [
            {
              "parameter": "withUnitTests",
              "equals": false
            },
            {
              "any": [
                {
                  "parameter": "project",
                  "equals": "python"
                },
                {
                  "parameter": "author",
                  "equals": "John Doe"
                },
                {
                  "parameter": "someNumber",
                  "notEquals": 5
                }
              ]
            }
          ]
        }
      }
    ]

  }
}